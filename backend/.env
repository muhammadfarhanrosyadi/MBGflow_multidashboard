# ============================================================
# SCM MBG Backend — Environment Variables
# ============================================================
# Salin file ini: copy .env.example .env
# Jangan commit file .env ke version control!
# ============================================================

# --- Server ---
PORT=5000
NODE_ENV=development

# --- Database MySQL (XAMPP) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=SCM_MBG

# --- Google Gemini AI ---
# Dapatkan API Key di: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- Security ---
# Generate strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
